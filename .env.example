# ─────────────────────────────────────────────────────────────────────────────
# Frank Oge Portfolio — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API Key — powers the chatbot assistant
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API Key — powers the contact form email delivery
# Get yours at: https://resend.com (free tier available)
# After adding, uncomment the Resend block in /src/app/api/contact/route.ts
RESEND_API_KEY=your_resend_api_key_here

# Site URL — used for OG images, sitemaps, and canonical URLs
NEXT_PUBLIC_SITE_URL=https://frankoge.com
